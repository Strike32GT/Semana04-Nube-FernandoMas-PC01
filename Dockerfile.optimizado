FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

RUN python -m pip install --no-cache-dir --no-compile flask && \
    find /usr/local -depth \( -type d -a -name __pycache__ \) -exec rm -rf {} +

COPY app.py ./
COPY templates ./templates

EXPOSE 8000

CMD ["python", "-u", "app.py"]
